---
import { Image } from 'astro:assets'
import logo from '@assets/logo.png'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
---

<footer class="border-t border-border bg-surface-card">
  <div class="max-w-6xl mx-auto px-6 py-14">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-12">
      <!-- Brand column -->
      <div class="col-span-2">
        <a href={`/${locale}/`} class="flex items-center no-underline mb-4">
          <Image src={logo} alt="Gobbly" height={32} class="h-8 w-auto" />
        </a>
        <p class="text-sm text-text-secondary leading-relaxed max-w-xs">
          {t.footer.tagline}
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-4">{t.footer.product}</h4>
        <ul class="space-y-2.5">
          <li><a href="#features" class="text-sm text-text-secondary hover:text-text-primary transition-colors">{t.footer.productFeatures}</a></li>
          <li><a href="#pricing" class="text-sm text-text-secondary hover:text-text-primary transition-colors">{t.footer.productPricing}</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-4">{t.footer.company}</h4>
        <ul class="space-y-2.5">
          <li><a href={`/${locale}/about/`} class="text-sm text-text-secondary hover:text-text-primary transition-colors">{t.footer.companyAbout}</a></li>
          <li><a href={`/${locale}/contact/`} class="text-sm text-text-secondary hover:text-text-primary transition-colors">{t.footer.companyContact}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-4">{t.footer.legal}</h4>
        <ul class="space-y-2.5">
          <li><a href={`/${locale}/privacy/`} class="text-sm text-text-secondary hover:text-text-primary transition-colors">{t.footer.legalPrivacy}</a></li>
          <li><a href={`/${locale}/terms/`} class="text-sm text-text-secondary hover:text-text-primary transition-colors">{t.footer.legalTerms}</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-border">
      <p class="text-xs text-text-muted text-center md:text-left">{t.footer.copyright}</p>
    </div>
  </div>
</footer>
