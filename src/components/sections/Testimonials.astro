---
import SectionHeader from '@components/ui/SectionHeader.astro'
import StarRating from '@components/ui/StarRating.astro'

const testimonials = [
  {
    delay: 1,
    quote: '&ldquo;We cut order errors by 80% the first week. The kitchen display alone saved us from constant miscommunication during rush hours.&rdquo;',
    initials: 'MP',
    gradient: 'from-brand to-brand-dark',
    name: 'Marta P&eacute;rez',
    role: 'Owner, La Bodeguita',
  },
  {
    delay: 2,
    quote: '&ldquo;Our customers love the QR ordering. They scan, browse the menu with allergen info, and pay — all without waiting for a waiter. Tips went up 15%.&rdquo;',
    initials: 'JL',
    gradient: 'from-terracotta to-amber',
    name: 'Joan Llu&iacute;s',
    role: 'Manager, Can Roca Petit',
  },
  {
    delay: 3,
    quote: '&ldquo;Setting up took 20 minutes. The VeriFactu invoicing was the killer feature for us — no more juggling a separate billing system.&rdquo;',
    initials: 'AG',
    gradient: 'from-blue to-blue/70',
    name: 'Ana Garc&iacute;a',
    role: 'Co-founder, Grupo Umami',
  },
]
---

<section class="py-20 md:py-28 bg-surface-card border-y border-border">
  <div class="max-w-6xl mx-auto px-6">
    <SectionHeader label="Testimonials" title="Loved by restaurateurs" />

    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class={`fade-up fade-up-delay-${t.delay} testimonial-card bg-surface rounded-2xl border border-border p-8`}>
          <StarRating />
          <blockquote class="text-text-primary leading-relaxed mb-6" set:html={t.quote} />
          <div class="flex items-center gap-3">
            <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${t.gradient} flex items-center justify-center text-white text-sm font-semibold`}>{t.initials}</div>
            <div>
              <div class="text-sm font-semibold text-text-primary" set:html={t.name} />
              <div class="text-xs text-text-muted">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
