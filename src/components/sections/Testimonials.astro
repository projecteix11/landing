---
import SectionHeader from '@components/ui/SectionHeader.astro'
import StarRating from '@components/ui/StarRating.astro'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)

const testimonialConfig = [
  { delay: 1, initials: 'MP', gradient: 'from-brand to-brand-dark' },
  { delay: 2, initials: 'JL', gradient: 'from-terracotta to-amber' },
  { delay: 3, initials: 'AG', gradient: 'from-blue to-blue/70' },
]
---

<section class="py-20 md:py-28 bg-surface-card border-y border-border">
  <div class="max-w-6xl mx-auto px-6">
    <SectionHeader label={t.testimonials.label} title={t.testimonials.title} />

    <div class="grid md:grid-cols-3 gap-6">
      {testimonialConfig.map((config, i) => (
        <div class={`fade-up fade-up-delay-${config.delay} testimonial-card bg-surface rounded-2xl border border-border p-8`}>
          <StarRating />
          <blockquote class="text-text-primary leading-relaxed mb-6">{t.testimonials.items[i].quote}</blockquote>
          <div class="flex items-center gap-3">
            <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${config.gradient} flex items-center justify-center text-white text-sm font-semibold`}>{config.initials}</div>
            <div>
              <div class="text-sm font-semibold text-text-primary">{t.testimonials.items[i].name}</div>
              <div class="text-xs text-text-muted">{t.testimonials.items[i].role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
