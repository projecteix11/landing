---
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
---

<section class="py-16 md:py-20 border-y border-border bg-surface">
  <div class="max-w-6xl mx-auto px-6">
    <p class="text-center text-xs font-semibold uppercase tracking-widest text-brand mb-10">{t.stats.label}</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0 md:divide-x md:divide-border">
      {t.stats.items.map((item, i) => (
        <div class={`fade-up fade-up-delay-${i + 1} flex flex-col items-center text-center px-6`}>
          <span class="font-display text-4xl md:text-5xl font-bold text-text-primary tracking-tight">{item.value}</span>
          <span class="mt-2 text-sm text-text-muted">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
