---
import Layout from '@layouts/Layout.astro'
import Navbar from '@components/layout/Navbar.astro'
import Footer from '@components/layout/Footer.astro'
import Breadcrumbs from '@components/ui/Breadcrumbs.astro'
import JsonLd from '@components/ui/JsonLd.astro'
import '@styles/global.css'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props {
  locale: Locale
  comparisonKey: 'revoXef' | 'coverManager' | 'square'
  path: string
}

const { locale, comparisonKey, path } = Astro.props
const t = getTranslations(locale)
const c = t.comparisons[comparisonKey]
const comp = t.comparisons

const competitorNames: Record<string, string> = {
  revoXef: 'Revo XEF',
  coverManager: 'CoverManager',
  square: 'Square',
}
const competitorName = competitorNames[comparisonKey]
---

<Layout locale={locale} title={`${c.title} — Gobbly`} description={c.description} path={path}>
  <Navbar locale={locale} />
  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <!-- Breadcrumbs -->
    <div class="max-w-5xl mx-auto px-6 pt-4">
      <Breadcrumbs locale={locale} items={[
        { label: t.nav.home, href: `/${locale}/` },
        { label: comp.breadcrumbCompare },
        { label: c.title },
      ]} />
    </div>

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 text-center mb-20 mt-8">
      <div class="fade-up">
        <h1 class="font-display text-4xl md:text-6xl tracking-tight mb-6">{c.heroTitle}</h1>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto mb-8">{c.heroSubtitle}</p>
        <a href={`/${locale}/contact/`} class="inline-flex items-center px-7 py-3.5 bg-text-primary text-white text-sm font-semibold rounded-full hover:bg-text-secondary transition-colors">
          {c.ctaButton}
        </a>
      </div>
    </section>

    <!-- Feature comparison table -->
    <section class="py-16 md:py-20 bg-surface-card border-y border-border">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="fade-up text-xs font-semibold text-brand uppercase tracking-widest mb-4">{comp.vsLabel}</p>
          <h2 class="fade-up fade-up-delay-1 font-display text-3xl md:text-5xl tracking-tight">{comp.featureTableTitle}</h2>
        </div>
        <div class="fade-up fade-up-delay-2 rounded-2xl border border-border bg-surface overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border bg-brand-soft">
                <th class="text-left py-4 px-6 font-semibold text-text-primary"></th>
                <th class="py-4 px-4 font-semibold text-brand text-center">{comp.gobblyColumn}</th>
                <th class="py-4 px-4 font-semibold text-text-secondary text-center">{competitorName}</th>
              </tr>
            </thead>
            <tbody>
              {c.features.map((feature: { name: string; gobbly: boolean; competitor: boolean }, i: number) => (
                <tr class={`border-b border-border ${i % 2 === 0 ? '' : 'bg-surface-card/50'}`}>
                  <td class="py-3.5 px-6 text-text-primary font-medium">{feature.name}</td>
                  <td class="py-3.5 px-4 text-center">
                    {feature.gobbly ? (
                      <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-brand-soft">
                        <svg class="w-4 h-4 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      </span>
                    ) : (
                      <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-terracotta-soft">
                        <svg class="w-4 h-4 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                      </span>
                    )}
                  </td>
                  <td class="py-3.5 px-4 text-center">
                    {feature.competitor ? (
                      <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-brand-soft">
                        <svg class="w-4 h-4 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                      </span>
                    ) : (
                      <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-terracotta-soft">
                        <svg class="w-4 h-4 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                      </span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Key advantages -->
    <section class="py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-6">
          {c.advantages.map((advantage: { title: string; description: string }, i: number) => (
            <div class={`fade-up fade-up-delay-${(i % 2) + 1} rounded-2xl border border-border bg-surface-card p-8`}>
              <div class={`w-12 h-12 rounded-xl ${i % 2 === 0 ? 'bg-brand-soft' : 'bg-amber-soft'} flex items-center justify-center mb-4`}>
                <svg class={`w-6 h-6 ${i % 2 === 0 ? 'text-brand' : 'text-amber'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-text-primary mb-2">{advantage.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{advantage.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing comparison -->
    <section class="py-16 md:py-20 bg-surface-card border-y border-border">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-14">
          <h2 class="fade-up font-display text-3xl md:text-5xl tracking-tight">{comp.pricingCompareTitle}</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="fade-up fade-up-delay-1 rounded-2xl border-2 border-brand bg-surface p-8 text-center">
            <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-3">{comp.gobblyColumn}</p>
            <p class="font-display text-3xl md:text-4xl font-bold text-text-primary mb-2">{c.pricingGobbly}</p>
          </div>
          <div class="fade-up fade-up-delay-2 rounded-2xl border border-border bg-surface p-8 text-center">
            <p class="text-xs font-semibold text-text-secondary uppercase tracking-widest mb-3">{competitorName}</p>
            <p class="font-display text-3xl md:text-4xl font-bold text-text-secondary mb-2">{c.pricingCompetitor}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Migration CTA -->
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="fade-up">
          <h2 class="font-display text-3xl md:text-5xl tracking-tight mb-4">{c.ctaTitle}</h2>
          <p class="text-text-secondary text-lg max-w-xl mx-auto mb-8">{c.ctaSubtitle}</p>
          <a href={`/${locale}/contact/`} class="inline-flex items-center px-8 py-4 bg-text-primary text-white font-semibold rounded-full hover:bg-text-secondary transition-colors text-lg">
            {c.ctaButton}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} />

  <JsonLd schema={{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": `Gobbly — ${c.title}`,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": c.description,
    "url": `https://gobbly.app/${locale}${path}`,
    "offers": {
      "@type": "Offer",
      "price": "19",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Gobbly",
      "url": "https://gobbly.app"
    }
  }} />
</Layout>
