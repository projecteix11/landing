---
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
---

<section class="relative overflow-hidden hero-grain pt-28 pb-20 md:pt-36 md:pb-28">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-hero-gradient-start to-hero-gradient-end -z-10"></div>
  <!-- Decorative blob -->
  <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-brand/[0.04] rounded-full blur-[120px] -z-10"></div>

  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto">
      <!-- Badge -->
      <div class="fade-up inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-soft border border-brand/20 text-brand-dark text-xs font-semibold tracking-wide uppercase mb-8">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
        {t.hero.badge}
      </div>

      <!-- Headline -->
      <h1 class="fade-up fade-up-delay-1 font-display text-5xl md:text-7xl leading-[1.05] tracking-tight text-text-primary mb-6">
        {t.hero.titleLine1}<br/>
        <span class="text-brand">{t.hero.titleHighlight}</span>
      </h1>

      <!-- Subtitle -->
      <p class="fade-up fade-up-delay-2 text-lg md:text-xl text-text-secondary leading-relaxed max-w-xl mx-auto mb-10">
        {t.hero.subtitle}
      </p>

      <!-- CTAs -->
      <div class="fade-up fade-up-delay-3 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`/${locale}/contact/`} class="inline-flex items-center gap-2 px-7 py-3.5 bg-brand text-white text-sm font-semibold rounded-full hover:bg-brand-dark transition-colors shadow-[0_2px_16px_-4px_rgba(34,197,94,0.4)]">
          {t.hero.ctaPrimary}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
        <a href="#how-it-works" class="inline-flex items-center gap-2 px-7 py-3.5 text-sm font-semibold text-text-secondary rounded-full border border-border hover:border-border-strong hover:text-text-primary transition-colors">
          {t.hero.ctaSecondary}
        </a>
      </div>
    </div>

    <!-- Floating UI Mockups -->
    <div class="relative mt-16 md:mt-24 max-w-4xl mx-auto">
      <!-- Main dashboard mockup -->
      <div class="fade-up fade-up-delay-4 relative bg-surface-card rounded-2xl border border-border shadow-[0_24px_80px_-16px_rgba(28,25,23,0.08)] overflow-hidden">
        <!-- Mockup top bar -->
        <div class="flex items-center gap-2 px-5 py-3 border-b border-border bg-surface-elevated">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-red-400/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-amber/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-brand/60"></div>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="px-4 py-1 bg-surface rounded-md text-[11px] text-text-muted font-mono">app.gobbly.io/dashboard</div>
          </div>
          <div class="w-12"></div>
        </div>
        <!-- Dashboard content mockup -->
        <div class="p-6 md:p-8">
          <div class="flex gap-6">
            <!-- Sidebar mock -->
            <div class="hidden md:flex flex-col gap-1 w-44 shrink-0">
              <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-brand-soft">
                <div class="w-4 h-4 rounded bg-brand/30"></div>
                <div class="h-2.5 w-16 rounded bg-brand/40"></div>
              </div>
              <div class="flex items-center gap-2 px-3 py-2 rounded-lg">
                <div class="w-4 h-4 rounded bg-text-muted/20"></div>
                <div class="h-2.5 w-12 rounded bg-text-muted/20"></div>
              </div>
              <div class="flex items-center gap-2 px-3 py-2 rounded-lg">
                <div class="w-4 h-4 rounded bg-text-muted/20"></div>
                <div class="h-2.5 w-20 rounded bg-text-muted/20"></div>
              </div>
              <div class="flex items-center gap-2 px-3 py-2 rounded-lg">
                <div class="w-4 h-4 rounded bg-text-muted/20"></div>
                <div class="h-2.5 w-14 rounded bg-text-muted/20"></div>
              </div>
              <div class="flex items-center gap-2 px-3 py-2 rounded-lg">
                <div class="w-4 h-4 rounded bg-text-muted/20"></div>
                <div class="h-2.5 w-18 rounded bg-text-muted/20"></div>
              </div>
            </div>
            <!-- Main content mock -->
            <div class="flex-1 space-y-5">
              <div class="flex items-center justify-between">
                <div class="h-4 w-28 rounded bg-text-primary/15"></div>
                <div class="flex gap-2">
                  <div class="h-8 w-20 rounded-lg bg-brand/10 border border-brand/20"></div>
                  <div class="h-8 w-8 rounded-lg bg-surface-elevated border border-border"></div>
                </div>
              </div>
              <!-- Stats row -->
              <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                <div class="p-4 rounded-xl bg-surface-elevated border border-border">
                  <div class="h-2 w-12 rounded bg-text-muted/20 mb-3"></div>
                  <div class="font-display text-2xl text-text-primary">24</div>
                  <div class="h-2 w-16 rounded bg-brand/20 mt-2"></div>
                </div>
                <div class="p-4 rounded-xl bg-surface-elevated border border-border">
                  <div class="h-2 w-16 rounded bg-text-muted/20 mb-3"></div>
                  <div class="font-display text-2xl text-text-primary">&euro;1,847</div>
                  <div class="h-2 w-14 rounded bg-amber-soft mt-2"></div>
                </div>
                <div class="p-4 rounded-xl bg-surface-elevated border border-border">
                  <div class="h-2 w-14 rounded bg-text-muted/20 mb-3"></div>
                  <div class="font-display text-2xl text-text-primary">89%</div>
                  <div class="h-2 w-12 rounded bg-blue-soft mt-2"></div>
                </div>
                <div class="p-4 rounded-xl bg-surface-elevated border border-border">
                  <div class="h-2 w-10 rounded bg-text-muted/20 mb-3"></div>
                  <div class="font-display text-2xl text-text-primary">12</div>
                  <div class="h-2 w-18 rounded bg-terracotta-soft mt-2"></div>
                </div>
              </div>
              <!-- Table grid mock -->
              <div class="grid grid-cols-4 md:grid-cols-6 gap-2">
                <div class="aspect-square rounded-xl bg-brand/15 border border-brand/20 flex items-center justify-center text-[10px] font-semibold text-brand-dark">T1</div>
                <div class="aspect-square rounded-xl bg-brand/15 border border-brand/20 flex items-center justify-center text-[10px] font-semibold text-brand-dark">T2</div>
                <div class="aspect-square rounded-xl bg-surface-elevated border border-border flex items-center justify-center text-[10px] font-semibold text-text-muted">T3</div>
                <div class="aspect-square rounded-xl bg-amber-soft border border-amber/20 flex items-center justify-center text-[10px] font-semibold text-amber">T4</div>
                <div class="aspect-square rounded-xl bg-surface-elevated border border-border flex items-center justify-center text-[10px] font-semibold text-text-muted">T5</div>
                <div class="aspect-square rounded-xl bg-brand/15 border border-brand/20 flex items-center justify-center text-[10px] font-semibold text-brand-dark">T6</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating kitchen card -->
      <div class="float-slow absolute -top-6 -right-4 md:-right-12 bg-surface-card rounded-xl border border-border shadow-[0_12px_40px_-8px_rgba(28,25,23,0.08)] p-4 w-52 hidden sm:block">
        <div class="text-[11px] font-semibold text-text-secondary uppercase tracking-wider mb-3">{t.hero.mockupKitchenLabel}</div>
        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <span class="text-xs text-text-primary">{t.hero.mockupRisotto}</span>
            <span class="px-2 py-0.5 text-[10px] font-semibold rounded-full bg-amber/15 text-amber badge-pulse">{t.hero.mockupCooking}</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-text-primary">{t.hero.mockupCaesarSalad}</span>
            <span class="px-2 py-0.5 text-[10px] font-semibold rounded-full bg-blue-soft text-blue">{t.hero.mockupReady}</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-text-primary">{t.hero.mockupGrilledSalmon}</span>
            <span class="px-2 py-0.5 text-[10px] font-semibold rounded-full bg-gray-100 text-text-muted">{t.hero.mockupPending}</span>
          </div>
        </div>
      </div>

      <!-- Floating QR card -->
      <div class="float-medium absolute -bottom-4 -left-4 md:-left-10 bg-surface-card rounded-xl border border-border shadow-[0_12px_40px_-8px_rgba(28,25,23,0.08)] p-4 w-44 hidden sm:block">
        <div class="text-[11px] font-semibold text-text-secondary uppercase tracking-wider mb-3">{t.hero.mockupTableQr}</div>
        <!-- QR code mockup -->
        <div class="aspect-square bg-text-primary rounded-lg p-3 mb-3">
          <div class="w-full h-full grid grid-cols-7 grid-rows-7 gap-0.5">
            <div class="bg-white rounded-[1px] col-span-3 row-span-3"></div>
            <div class="bg-white/20 rounded-[1px]"></div>
            <div class="bg-white rounded-[1px] col-span-3 row-span-3"></div>
            <div class="bg-white/40 rounded-[1px]"></div>
            <div class="bg-white/20 rounded-[1px]"></div>
            <div class="bg-white/60 rounded-[1px]"></div>
            <div class="bg-white/30 rounded-[1px]"></div>
            <div class="bg-white/50 rounded-[1px]"></div>
            <div class="bg-white/20 rounded-[1px]"></div>
            <div class="bg-white/70 rounded-[1px]"></div>
            <div class="bg-brand rounded-[1px] col-span-1 row-span-1"></div>
            <div class="bg-white/40 rounded-[1px]"></div>
            <div class="bg-white/60 rounded-[1px]"></div>
            <div class="bg-white rounded-[1px] col-span-3 row-span-3"></div>
            <div class="bg-white/30 rounded-[1px]"></div>
            <div class="bg-white/50 rounded-[1px]"></div>
            <div class="bg-white/20 rounded-[1px]"></div>
            <div class="bg-white/40 rounded-[1px]"></div>
          </div>
        </div>
        <div class="text-[10px] text-text-muted text-center">{t.hero.mockupScanToOrder}</div>
      </div>

      <!-- Floating payment badge -->
      <div class="float-fast absolute top-1/2 -right-2 md:-right-6 bg-brand text-white rounded-full px-4 py-2 shadow-[0_8px_24px_-4px_rgba(34,197,94,0.3)] hidden sm:flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
        <span class="text-xs font-semibold">{t.hero.mockupSplitPaid}</span>
      </div>
    </div>
  </div>
</section>
