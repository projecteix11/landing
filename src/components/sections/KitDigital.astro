---
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)

const colorMap: Record<string, { badge: string; amount: string }> = {
  brand:  { badge: 'bg-brand-soft text-brand border-brand/20',   amount: 'text-brand' },
  amber:  { badge: 'bg-amber/10 text-amber border-amber/20',      amount: 'text-amber' },
  blue:   { badge: 'bg-blue/10 text-blue border-blue/20',         amount: 'text-blue' },
}
---

<section class="py-20 md:py-28 bg-surface-card border-y border-border">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">

      <!-- Left: text -->
      <div class="fade-up fade-up-delay-1">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-soft border border-brand/20 mb-6">
          <!-- EU flag stars icon -->
          <svg class="w-4 h-4 text-brand" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l.5 1.5H14l-1.25.9.5 1.6L12 5.1l-1.25.9.5-1.6L10 3.5h1.5L12 2z"/>
            <path d="M12 18l.5 1.5H14l-1.25.9.5 1.6L12 21.1l-1.25.9.5-1.6L10 19.5h1.5L12 18z"/>
            <path d="M5 10l.5 1.5H7l-1.25.9.5 1.6L5 13.1l-1.25.9.5-1.6L3 12.5h1.5L5 10z"/>
            <path d="M19 10l.5 1.5H21l-1.25.9.5 1.6L19 13.1l-1.25.9.5-1.6L17 12.5h1.5L19 10z"/>
          </svg>
          <span class="text-xs font-semibold text-brand">{t.kitDigital.badge}</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-display font-bold text-text-primary leading-tight mb-4">
          {t.kitDigital.title}
        </h2>
        <p class="text-text-secondary leading-relaxed mb-8">
          {t.kitDigital.description}
        </p>

        <!-- Segments -->
        <div class="space-y-3 mb-8">
          {t.kitDigital.segments.map((seg) => {
            const c = colorMap[seg.color] ?? colorMap.brand
            return (
              <div class="flex items-center justify-between p-4 rounded-xl border border-border bg-surface">
                <span class="text-sm text-text-secondary">{seg.label}</span>
                <span class={`text-sm font-bold ${c.amount}`}>{seg.amount}</span>
              </div>
            )
          })}
        </div>

        <a
          href={`/${locale}/kit-digital/`}
          class="inline-flex items-center gap-2 px-6 py-3 bg-brand text-white text-sm font-semibold rounded-full hover:bg-brand-dark transition-colors shadow-[0_2px_16px_-4px_rgba(34,197,94,0.4)]"
        >
          {t.kitDigital.learnMore}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- Right: steps -->
      <div class="fade-up fade-up-delay-2 space-y-6">
        {t.kitDigital.steps.map((step) => (
          <div class="flex gap-5">
            <div class="shrink-0 w-10 h-10 rounded-xl bg-brand-soft border border-brand/20 flex items-center justify-center">
              <span class="text-xs font-bold text-brand">{step.step}</span>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text-primary mb-1">{step.title}</h3>
              <p class="text-sm text-text-secondary leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
