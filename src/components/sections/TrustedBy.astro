---
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
---

<section class="py-12 border-y border-border bg-surface-card">
  <div class="max-w-6xl mx-auto px-6">
    <div class="fade-up flex flex-col md:flex-row items-center justify-center gap-6 md:gap-12">
      <p class="text-sm text-text-muted font-medium shrink-0">{t.trustedBy.label}</p>
      <div class="flex items-center gap-8 md:gap-12 opacity-30">
        <span class="font-display text-xl text-text-primary tracking-tight">Vinos&amp;Tapas</span>
        <span class="font-display text-xl text-text-primary tracking-tight hidden sm:block">La Boqueria</span>
        <span class="font-display text-xl text-text-primary tracking-tight">Umami</span>
        <span class="font-display text-xl text-text-primary tracking-tight hidden sm:block">Fuego</span>
        <span class="font-display text-xl text-text-primary tracking-tight hidden md:block">Oliva</span>
      </div>
    </div>
  </div>
</section>
