---
import SectionHeader from '@components/ui/SectionHeader.astro'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
---

<section class="py-20 md:py-28 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <SectionHeader
      label={t.appScreenshots.label}
      title={t.appScreenshots.title}
      description={t.appScreenshots.description}
    />

    <!-- Tab buttons -->
    <div class="flex justify-center gap-2 mb-8 flex-wrap">
      {t.appScreenshots.tabs.map((tab, i) => (
        <button
          data-tab={tab.id}
          class:list={[
            'screenshot-tab px-4 py-2 rounded-full text-sm font-medium transition-colors border',
            i === 0
              ? 'bg-brand text-white border-brand'
              : 'bg-surface-card text-text-secondary border-border hover:border-brand hover:text-brand',
          ]}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <!-- Screenshot panels -->
    <div class="relative rounded-2xl overflow-hidden border border-border shadow-2xl">

      <!-- ── Dashboard ─────────────────────────────────────────────────── -->
