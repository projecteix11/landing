---
import SectionHeader from '@components/ui/SectionHeader.astro'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)

const featureLinks = [
  `/${locale}/features/pos/`,
  `/${locale}/features/kitchen-display/`,
  `/${locale}/features/qr-menu/`,
  `/${locale}/features/payments/`,
]

const featureConfig = [
  {
    delay: 1,
    iconBg: 'bg-brand-soft',
    iconHoverBg: 'group-hover:bg-brand/15',
    iconColor: 'text-brand',
    iconPath: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />',
    tagVariants: ['default', 'default', 'default'],
  },
  {
    delay: 2,
    iconBg: 'bg-amber-soft',
    iconHoverBg: 'group-hover:bg-amber/15',
    iconColor: 'text-amber',
    iconPath: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />',
    tagVariants: ['amber', 'default', 'default'],
  },
  {
    delay: 3,
    iconBg: 'bg-terracotta-soft',
    iconHoverBg: 'group-hover:bg-terracotta/15',
    iconColor: 'text-terracotta',
    iconPath: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM13.5 19.5h.75v.75h-.75v-.75zM19.5 13.5h.75v.75h-.75v-.75zM19.5 19.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75z" />',
    tagVariants: ['default', 'default', 'default'],
  },
  {
    delay: 4,
    iconBg: 'bg-blue-soft',
    iconHoverBg: 'group-hover:bg-blue/15',
    iconColor: 'text-blue',
    iconPath: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />',
    tagVariants: ['default', 'default', 'default'],
  },
]

const tagClasses: Record<string, string> = {
  default: 'bg-surface-elevated border-border text-text-secondary',
  amber: 'bg-amber/10 border-amber/20 text-amber',
  brand: 'bg-brand/10 border-brand/20 text-brand',
}
---

<section id="features" class="py-20 md:py-28 bg-surface-card border-y border-border">
  <div class="max-w-6xl mx-auto px-6">
    <SectionHeader
      label={t.features.label}
      title={t.features.title}
      description={t.features.description}
    />

    <div class="grid md:grid-cols-2 gap-6">
      {featureConfig.map((feature, i) => (
        <a href={featureLinks[i]} class={`fade-up fade-up-delay-${feature.delay} feature-card group rounded-2xl border border-border bg-surface p-8 md:p-10 no-underline hover:border-brand/30 transition-colors`}>
          <div class="flex items-start gap-5">
            <div class={`w-14 h-14 rounded-2xl ${feature.iconBg} flex items-center justify-center shrink-0 ${feature.iconHoverBg} transition-colors`}>
              <svg class={`w-7 h-7 ${feature.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={feature.iconPath} />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-text-primary mb-2 group-hover:text-brand transition-colors">{t.features.items[i].title}</h3>
              <p class="text-text-secondary leading-relaxed">{t.features.items[i].description}</p>
              <div class="flex flex-wrap gap-2 mt-4">
                {t.features.items[i].tags.map((tag, j) => (
                  <span class={`px-2.5 py-1 text-[11px] font-medium rounded-full border ${tagClasses[feature.tagVariants[j]]}`}>{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
