---
import SectionHeader from '@components/ui/SectionHeader.astro'
---

<section class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <SectionHeader label="Why Gobbly" title="The chaos ends here" />

    <div class="grid md:grid-cols-3 gap-6">
      <!-- Card 1 -->
      <div class="fade-up fade-up-delay-1 feature-card bg-surface-card rounded-2xl border border-border p-8">
        <div class="w-12 h-12 rounded-xl bg-brand-soft flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m6.75 12H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            <line x1="6" y1="4" x2="16" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.6" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-2">No more paper tickets</h3>
        <p class="text-text-secondary text-[15px] leading-relaxed">
          Orders go straight from the table to the kitchen screen. No handwriting, no lost tickets, no miscommunication.
        </p>
      </div>

      <!-- Card 2 -->
      <div class="fade-up fade-up-delay-2 feature-card bg-surface-card rounded-2xl border border-border p-8">
        <div class="w-12 h-12 rounded-xl bg-amber-soft flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-2">Real-time kitchen sync</h3>
        <p class="text-text-secondary text-[15px] leading-relaxed">
          Kitchen staff see orders the moment they're placed. Status updates flow back instantly — pending, cooking, ready, delivered.
        </p>
      </div>

      <!-- Card 3 -->
      <div class="fade-up fade-up-delay-3 feature-card bg-surface-card rounded-2xl border border-border p-8">
        <div class="w-12 h-12 rounded-xl bg-blue-soft flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-text-primary mb-2">Customers pay their way</h3>
        <p class="text-text-secondary text-[15px] leading-relaxed">
          Diners scan the QR, pick what they ate, and split the bill however they like. Cash, card, or mixed — done in seconds.
        </p>
      </div>
    </div>
  </div>
</section>
