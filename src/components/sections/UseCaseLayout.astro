---
import Layout from '@layouts/Layout.astro'
import Navbar from '@components/layout/Navbar.astro'
import Footer from '@components/layout/Footer.astro'
import Breadcrumbs from '@components/ui/Breadcrumbs.astro'
import JsonLd from '@components/ui/JsonLd.astro'
import '@styles/global.css'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface UseCaseLink {
  title: string
  href: string
  description: string
}

interface Props {
  locale: Locale
  useCaseKey: 'restaurants' | 'bars' | 'foodTrucks'
  path: string
  emoji: string
}

const { locale, useCaseKey, path, emoji } = Astro.props
const t = getTranslations(locale)
const u = t.useCases[useCaseKey]

const allUseCases = {
  restaurants: { key: 'restaurants', path: '/solutions/restaurants/' },
  bars: { key: 'bars', path: '/solutions/bars-cafes/' },
  foodTrucks: { key: 'foodTrucks', path: '/solutions/food-trucks/' },
} as const

const otherUseCases: UseCaseLink[] = Object.entries(allUseCases)
  .filter(([key]) => key !== useCaseKey)
  .map(([key, val]) => ({
    title: t.useCases[key as keyof typeof allUseCases].title,
    href: `/${locale}${val.path}`,
    description: t.useCases[key as keyof typeof allUseCases].heroSubtitle,
  }))

const featureIcons = [
  '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />',
  '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />',
]

const featureColors = [
  { bg: 'bg-brand-soft', text: 'text-brand' },
  { bg: 'bg-amber-soft', text: 'text-amber' },
  { bg: 'bg-terracotta-soft', text: 'text-terracotta' },
  { bg: 'bg-blue-soft', text: 'text-blue' },
  { bg: 'bg-brand-soft', text: 'text-brand' },
  { bg: 'bg-amber-soft', text: 'text-amber' },
]

---

<Layout locale={locale} title={`${u.title} — Gobbly`} description={u.description} path={path}>
  <Navbar locale={locale} />
  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <!-- Breadcrumbs -->
    <div class="max-w-5xl mx-auto px-6 pt-4">
      <Breadcrumbs locale={locale} items={[
        { label: t.nav.home, href: `/${locale}/` },
        { label: t.useCases.breadcrumbSolutions },
        { label: u.title },
      ]} />
    </div>

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 text-center mb-20 mt-8">
      <div class="fade-up">
        <div class="text-5xl mb-6">{emoji}</div>
        <h1 class="font-display text-4xl md:text-6xl tracking-tight mb-6">{u.heroTitle}</h1>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto mb-8">{u.heroSubtitle}</p>
        <a href={`/${locale}/contact/`} class="inline-flex items-center px-7 py-3.5 bg-text-primary text-white text-sm font-semibold rounded-full hover:bg-text-secondary transition-colors">
          {u.ctaButton}
        </a>
      </div>
    </section>

    <!-- Pain points -->
    <section class="py-16 md:py-20 bg-surface-card border-y border-border">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="fade-up text-xs font-semibold text-terracotta uppercase tracking-widest mb-4">{u.painPointsLabel}</p>
          <h2 class="fade-up fade-up-delay-1 font-display text-3xl md:text-5xl tracking-tight">{u.painPointsTitle}</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {u.painPoints.map((point, i) => (
            <div class={`fade-up fade-up-delay-${i + 1} rounded-2xl border border-border bg-surface p-8`}>
              <div class="w-10 h-10 rounded-xl bg-terracotta-soft flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-text-primary mb-2">{point.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{point.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How Gobbly helps -->
    <section class="py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="fade-up text-xs font-semibold text-brand uppercase tracking-widest mb-4">{u.featuresLabel}</p>
          <h2 class="fade-up fade-up-delay-1 font-display text-3xl md:text-5xl tracking-tight">{u.featuresTitle}</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {u.features.map((feature, i) => (
            <div class={`fade-up fade-up-delay-${(i % 3) + 1} rounded-2xl border border-border bg-surface-card p-8`}>
              <div class={`w-12 h-12 rounded-xl ${featureColors[i % featureColors.length].bg} flex items-center justify-center mb-4`}>
                <svg class={`w-6 h-6 ${featureColors[i % featureColors.length].text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <Fragment set:html={featureIcons[i % featureIcons.length]} />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-text-primary mb-2">{feature.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Day in the life -->
    <section class="py-16 md:py-20 bg-surface-card border-y border-border">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="fade-up text-xs font-semibold text-brand uppercase tracking-widest mb-4">{u.workflowLabel}</p>
          <h2 class="fade-up fade-up-delay-1 font-display text-3xl md:text-5xl tracking-tight">{u.workflowTitle}</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {u.workflow.map((step, i) => (
            <div class={`fade-up fade-up-delay-${i + 1} text-center`}>
              <div class="w-14 h-14 rounded-full bg-brand text-white text-xl font-bold flex items-center justify-center mx-auto mb-5">
                {i + 1}
              </div>
              <h3 class="text-lg font-semibold text-text-primary mb-2">{step.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Key stats/benefits -->
    <section class="py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {u.benefits.map((benefit, i) => (
            <div class={`fade-up fade-up-delay-${(i % 4) + 1} rounded-2xl border border-border bg-surface-card p-8 text-center`}>
              <p class="text-3xl md:text-4xl font-display font-bold text-brand mb-3">{benefit.stat}</p>
              <p class="text-text-secondary text-sm leading-relaxed">{benefit.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other solutions -->
    <section class="py-16 md:py-20 bg-surface-card border-y border-border">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-14">
          <h2 class="fade-up font-display text-3xl md:text-4xl tracking-tight mb-4">{u.exploreTitle}</h2>
          <p class="fade-up fade-up-delay-1 text-text-secondary max-w-lg mx-auto">{u.exploreSubtitle}</p>
        </div>
        <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
          {otherUseCases.map((uc, i) => (
            <a href={uc.href} class={`fade-up fade-up-delay-${i + 1} group rounded-2xl border border-border bg-surface p-8 hover:border-brand/30 transition-colors no-underline`}>
              <h3 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-brand transition-colors">{uc.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed line-clamp-2">{uc.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="fade-up">
          <h2 class="font-display text-3xl md:text-5xl tracking-tight mb-6">{u.ctaTitle}</h2>
          <a href={`/${locale}/contact/`} class="inline-flex items-center px-8 py-4 bg-text-primary text-white font-semibold rounded-full hover:bg-text-secondary transition-colors text-lg">
            {u.ctaButton}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} />

  <JsonLd schema={{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": `Gobbly — ${u.title}`,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": u.description,
    "url": `https://gobbly.app/${locale}${path}`,
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Gobbly",
      "url": "https://gobbly.app"
    }
  }} />
</Layout>
