---
import type { Locale } from '@i18n/types'
import { locales, getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale: currentLocale } = Astro.props
const t = getTranslations(currentLocale)

const pathname = Astro.url.pathname
const pathWithoutLocale = pathname.replace(/^\/(en|es|ca)/, '') || '/'

const languageLabels: Record<Locale, string> = {
  en: 'EN',
  es: 'ES',
  ca: 'CA',
}
---

<div class="relative lang-switcher-root">
  <button
    class="lang-switcher-btn flex items-center gap-1.5 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors px-2 py-1 rounded-lg hover:bg-surface-elevated cursor-pointer"
    aria-label={t.languageSwitcher.label}
    aria-expanded="false"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418" />
    </svg>
    <span>{languageLabels[currentLocale]}</span>
    <svg class="w-3 h-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <div class="lang-switcher-dropdown absolute left-0 top-full mt-1 bg-surface-card border border-border rounded-xl shadow-lg py-1 min-w-[140px] hidden z-50">
    {locales.map((loc) => (
      <a
        href={`/${loc}${pathWithoutLocale}`}
        class:list={[
          'flex items-center gap-2 px-4 py-2 text-sm transition-colors',
          loc === currentLocale
            ? 'text-brand font-semibold bg-brand-soft'
            : 'text-text-secondary hover:text-text-primary hover:bg-surface-elevated',
        ]}
      >
        <span>{languageLabels[loc]}</span>
        <span class="text-text-muted">{t.languageSwitcher[loc]}</span>
      </a>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.lang-switcher-root').forEach((switcher) => {
    const btn = switcher.querySelector<HTMLButtonElement>('.lang-switcher-btn')
    const dropdown = switcher.querySelector<HTMLElement>('.lang-switcher-dropdown')
    if (!btn || !dropdown) return

    btn.addEventListener('click', (e) => {
      e.stopPropagation()
      dropdown.classList.toggle('hidden')
      btn.setAttribute('aria-expanded', String(!dropdown.classList.contains('hidden')))
    })

    document.addEventListener('click', (e) => {
      if (!switcher.contains(e.target as Node)) {
        dropdown.classList.add('hidden')
        btn.setAttribute('aria-expanded', 'false')
      }
    })
  })
</script>
