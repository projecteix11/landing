---
import Layout from '@layouts/Layout.astro'
import JsonLd from '@components/ui/JsonLd.astro'
import Navbar from '@components/layout/Navbar.astro'
import Hero from '@components/sections/Hero.astro'
import TrustedBy from '@components/sections/TrustedBy.astro'
import ProblemSolution from '@components/sections/ProblemSolution.astro'
import Features from '@components/sections/Features.astro'
import HowItWorks from '@components/sections/HowItWorks.astro'
import Testimonials from '@components/sections/Testimonials.astro'
import Pricing from '@components/sections/Pricing.astro'
import CtaSection from '@components/sections/CtaSection.astro'
import Footer from '@components/layout/Footer.astro'
import '@styles/global.css'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = getTranslations(locale)
---

<Layout locale={locale} title={t.meta.title} description={t.meta.description}>
  <Navbar locale={locale} />
  <main>
    <Hero locale={locale} />
    <TrustedBy locale={locale} />
    <ProblemSolution locale={locale} />
    <Features locale={locale} />
    <HowItWorks locale={locale} />
    {/* <Testimonials locale={locale} /> */}
    <Pricing locale={locale} />
    <CtaSection locale={locale} />
  </main>
  <Footer locale={locale} />
  <JsonLd schema={{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Gobbly",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": t.hero.subtitle,
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "EUR",
      "lowPrice": "0",
      "highPrice": "49",
      "offerCount": "3"
    }
  }} />
</Layout>
