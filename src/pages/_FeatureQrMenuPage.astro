---
import FeaturePageLayout from '@components/sections/FeaturePageLayout.astro'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
---

<FeaturePageLayout
  locale={locale}
  featureKey="qrMenu"
  path="/features/qr-menu/"
  emoji="📱"
  otherFeatures={[
    { title: t.featurePages.pos.title, href: `/${locale}/features/pos/`, description: t.featurePages.pos.description },
    { title: t.featurePages.kitchen.title, href: `/${locale}/features/kitchen-display/`, description: t.featurePages.kitchen.description },
    { title: t.featurePages.payments.title, href: `/${locale}/features/payments/`, description: t.featurePages.payments.description },
  ]}
/>
