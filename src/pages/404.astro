---
import Layout from '@layouts/Layout.astro'
import Navbar from '@components/layout/Navbar.astro'
import Footer from '@components/layout/Footer.astro'
import '@styles/global.css'
---

<Layout locale="en" title="Page Not Found — Gobbly" description="The page you're looking for doesn't exist.">
  <Navbar locale="en" />
  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <section class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-8xl font-display text-brand mb-6">404</p>
      <h1 class="font-display text-3xl md:text-5xl tracking-tight mb-4">Page Not Found</h1>
      <p class="text-text-secondary text-lg mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/en/" class="inline-flex items-center px-6 py-3 bg-text-primary text-white text-sm font-semibold rounded-full hover:bg-text-secondary transition-colors">
        Go Home
      </a>
    </section>
  </main>
  <Footer locale="en" />
</Layout>
