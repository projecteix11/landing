---
import Layout from '@layouts/Layout.astro'
import Breadcrumbs from '@components/ui/Breadcrumbs.astro'
import Navbar from '@components/layout/Navbar.astro'
import Footer from '@components/layout/Footer.astro'
import '@styles/global.css'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)

const colorMap: Record<string, { pill: string; amount: string; border: string }> = {
  brand: { pill: 'bg-brand-soft text-brand border-brand/20', amount: 'text-brand', border: 'border-brand/30' },
  amber: { pill: 'bg-amber/10 text-amber border-amber/20', amount: 'text-amber', border: 'border-amber/30' },
  blue:  { pill: 'bg-blue/10 text-blue border-blue/20',    amount: 'text-blue',  border: 'border-blue/30' },
}
---

<Layout locale={locale} title={`${t.kitDigitalPage.title} — Gobbly`} description={t.kitDigitalPage.description} path="/kit-digital/">
  <Navbar locale={locale} />
  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-5xl mx-auto px-6 pt-4">
      <Breadcrumbs locale={locale} items={[
        { label: t.nav.home, href: `/${locale}/` },
        { label: 'Kit Digital' },
      ]} />
    </div>

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 text-center mt-10 mb-20">
      <div class="fade-up">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-soft border border-brand/20 mb-6">
          <svg class="w-4 h-4 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-xs font-semibold text-brand">{t.kitDigitalPage.badge}</span>
        </div>
        <h1 class="font-display text-4xl md:text-5xl tracking-tight mb-6 text-text-primary">{t.kitDigitalPage.heroTitle}</h1>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto leading-relaxed">{t.kitDigitalPage.heroSubtitle}</p>
      </div>
    </section>

    <!-- What is Kit Digital -->
    <section class="max-w-4xl mx-auto px-6 mb-20">
      <div class="bg-surface-card rounded-2xl border border-border p-8 md:p-12 fade-up">
        <h2 class="text-2xl font-display font-bold text-text-primary mb-4">{t.kitDigitalPage.whatTitle}</h2>
        {t.kitDigitalPage.whatBody.split('\n\n').map((para) => (
          <p class="text-text-secondary leading-relaxed mb-4 last:mb-0">{para}</p>
        ))}
      </div>
    </section>

    <!-- Segments -->
    <section class="max-w-4xl mx-auto px-6 mb-20">
      <h2 class="text-2xl font-display font-bold text-text-primary mb-8 text-center">{t.kitDigitalPage.segmentsTitle}</h2>
      <div class="grid md:grid-cols-3 gap-4">
        {t.kitDigitalPage.segments.map((seg, i) => {
          const c = colorMap[seg.color] ?? colorMap.brand
          return (
            <div class:list={[`fade-up fade-up-delay-${i + 1} rounded-2xl border p-6 text-center`, c.border, 'bg-surface-card']}>
              <p class:list={['text-3xl font-display font-bold mb-2', c.amount]}>{seg.amount}</p>
              <p class="text-sm text-text-secondary">{seg.label}</p>
            </div>
          )
        })}
      </div>
    </section>

    <!-- Steps -->
    <section class="max-w-4xl mx-auto px-6 mb-20">
      <h2 class="text-2xl font-display font-bold text-text-primary mb-10 text-center">{t.kitDigitalPage.stepsTitle}</h2>
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-6 top-8 bottom-8 w-px bg-border hidden md:block"></div>
        <div class="space-y-8">
          {t.kitDigitalPage.steps.map((step, i) => (
            <div class:list={[`fade-up fade-up-delay-${(i % 3) + 1} flex gap-6`]}>
              <div class="shrink-0 w-12 h-12 rounded-full bg-brand text-white flex items-center justify-center font-display font-bold text-lg z-10">
                {step.step}
              </div>
              <div class="bg-surface-card rounded-2xl border border-border p-6 flex-1">
                <h3 class="text-base font-semibold text-text-primary mb-2">{step.title}</h3>
                <p class="text-sm text-text-secondary leading-relaxed">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Requirements -->
    <section class="max-w-4xl mx-auto px-6 mb-20">
      <div class="bg-surface-card rounded-2xl border border-border p-8 md:p-12 fade-up">
        <h2 class="text-2xl font-display font-bold text-text-primary mb-6">{t.kitDigitalPage.requirementsTitle}</h2>
        <ul class="space-y-3">
          {t.kitDigitalPage.requirements.map((req) => (
            <li class="flex items-start gap-3 text-sm text-text-secondary">
              <svg class="w-5 h-5 text-brand shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {req}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-4xl mx-auto px-6 mb-20">
      <h2 class="text-2xl font-display font-bold text-text-primary mb-8 text-center">{t.kitDigitalPage.faqTitle}</h2>
      <div class="space-y-3">
        {t.kitDigitalPage.faq.map((item, i) => (
          <details class:list={[`fade-up fade-up-delay-${(i % 3) + 1} group rounded-2xl border border-border bg-surface-card overflow-hidden`]}>
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none select-none">
              <span class="text-sm font-semibold text-text-primary">{item.question}</span>
              <svg class="w-4 h-4 text-text-muted shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm text-text-secondary leading-relaxed border-t border-border pt-4">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-4xl mx-auto px-6">
      <div class="fade-up rounded-2xl bg-brand p-10 text-center">
        <h2 class="text-2xl md:text-3xl font-display font-bold text-white mb-3">{t.kitDigitalPage.ctaTitle}</h2>
        <p class="text-white/80 mb-8 max-w-xl mx-auto">{t.kitDigitalPage.ctaSubtitle}</p>
        <a
          href={`/${locale}/contact/`}
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-white text-brand text-sm font-semibold rounded-full hover:bg-brand-soft transition-colors"
        >
          {t.kitDigitalPage.ctaButton}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
