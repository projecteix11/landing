---
import Layout from '@layouts/Layout.astro'
import Breadcrumbs from '@components/ui/Breadcrumbs.astro'
import JsonLd from '@components/ui/JsonLd.astro'
import Navbar from '@components/layout/Navbar.astro'
import Footer from '@components/layout/Footer.astro'
import '@styles/global.css'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)

const categoryKeys = ['general', 'pricing', 'features', 'technical', 'legal'] as const

const allFaqItems = categoryKeys.flatMap((key) =>
  t.faqPage.categories[key].items.map((item) => ({
    question: item.question,
    answer: item.answer,
  }))
)
---

<Layout locale={locale} title={`${t.faqPage.title} — Gobbly`} description={t.faqPage.description} path="/faq/">
  <Navbar locale={locale} />
  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-5xl mx-auto px-6 pt-4">
      <Breadcrumbs locale={locale} items={[
        { label: t.nav.home, href: `/${locale}/` },
        { label: t.faqPage.title },
      ]} />
    </div>

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 text-center mb-20">
      <div class="fade-up">
        <h1 class="font-display text-4xl md:text-6xl tracking-tight mb-6">{t.faqPage.heroTitle}</h1>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">{t.faqPage.heroSubtitle}</p>
      </div>
    </section>

    <!-- FAQ Categories -->
    <section class="max-w-3xl mx-auto px-6">
      {categoryKeys.map((key, catIndex) => (
        <div class={`fade-up ${catIndex > 0 ? 'mt-14' : ''}`}>
          <h2 class="font-display text-2xl md:text-3xl tracking-tight mb-2">{t.faqPage.categories[key].title}</h2>
          <div class="h-px bg-border mb-6" />
          <div class="space-y-3">
            {t.faqPage.categories[key].items.map((item) => (
              <details class="group rounded-xl border border-border bg-surface-card overflow-hidden">
                <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5 font-semibold text-text-primary select-none transition-colors hover:bg-surface-card/80">
                  <span>{item.question}</span>
                  <svg class="h-5 w-5 shrink-0 text-text-muted transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                  </svg>
                </summary>
                <div class="px-6 pb-5 text-text-secondary leading-relaxed">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- CTA -->
    <section class="max-w-3xl mx-auto px-6 mt-20">
      <div class="fade-up bg-surface-card rounded-2xl border border-border p-10 md:p-14 text-center">
        <h2 class="font-display text-2xl md:text-4xl tracking-tight mb-4">{t.faqPage.ctaTitle}</h2>
        <p class="text-text-secondary text-lg mb-8">{t.faqPage.ctaText}</p>
        <a href={`/${locale}/contact/`} class="inline-flex items-center gap-2 bg-brand hover:bg-brand-dark text-white font-semibold px-8 py-3 rounded-full transition-colors">
          {t.faqPage.ctaButton}
        </a>
      </div>
    </section>
  </main>
  <Footer locale={locale} />

  <JsonLd schema={{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": allFaqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      },
    })),
  }} />
</Layout>
