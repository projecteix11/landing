---
import Layout from '@layouts/Layout.astro'
import Navbar from '@components/layout/Navbar.astro'
import Hero from '@components/sections/Hero.astro'
import TrustedBy from '@components/sections/TrustedBy.astro'
import ProblemSolution from '@components/sections/ProblemSolution.astro'
import Features from '@components/sections/Features.astro'
import HowItWorks from '@components/sections/HowItWorks.astro'
import Testimonials from '@components/sections/Testimonials.astro'
import Pricing from '@components/sections/Pricing.astro'
import CtaSection from '@components/sections/CtaSection.astro'
import Footer from '@components/layout/Footer.astro'
import '@styles/global.css'
---

<Layout
  title="Gobbly — Restaurant Management, Simplified"
  description="All-in-one restaurant management platform. POS, kitchen display, digital menus, QR ordering, and smart payments — in a single app."
>
  <Navbar />
  <main>
    <Hero />
    <TrustedBy />
    <ProblemSolution />
    <Features />
    <HowItWorks />
    <Testimonials />
    <Pricing />
    <CtaSection />
  </main>
  <Footer />
</Layout>
