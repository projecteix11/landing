---
import Layout from '@layouts/Layout.astro'
import Navbar from '@components/layout/Navbar.astro'
import Footer from '@components/layout/Footer.astro'
import '@styles/global.css'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)
---

<Layout locale={locale} title={`${t.privacy.title} — Gobbly`} description={t.privacy.title} path="/privacy/">
  <Navbar locale={locale} />
  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <article class="max-w-3xl mx-auto px-6">
      <div class="fade-up mb-12">
        <h1 class="font-display text-4xl md:text-5xl tracking-tight mb-4">{t.privacy.title}</h1>
        <p class="text-sm text-text-muted">{t.privacy.lastUpdated}</p>
      </div>

      <div class="space-y-10">
        {t.privacy.sections.map((section, i) => (
          <section class={`fade-up fade-up-delay-${Math.min(i + 1, 4)}`}>
            <h2 class="text-xl font-semibold text-text-primary mb-3">{section.heading}</h2>
            <p class="text-text-secondary leading-relaxed">{section.content}</p>
          </section>
        ))}
      </div>
    </article>
  </main>
  <Footer locale={locale} />
</Layout>
