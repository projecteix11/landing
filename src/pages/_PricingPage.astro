---
import Layout from '@layouts/Layout.astro'
import Breadcrumbs from '@components/ui/Breadcrumbs.astro'
import Navbar from '@components/layout/Navbar.astro'
import Footer from '@components/layout/Footer.astro'
import JsonLd from '@components/ui/JsonLd.astro'
import CheckIcon from '@components/ui/CheckIcon.astro'
import '@styles/global.css'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)

const plans = [
  {
    name: t.pricingPage.starterName,
    subtitle: t.pricingPage.starterSubtitle,
    price: t.pricingPage.starterPrice,
    priceSuffix: t.pricingPage.starterPriceSuffix,
    features: t.pricingPage.starterFeatures,
    cta: t.pricingPage.starterCta,
    ctaStyle: 'border border-border text-text-primary hover:border-brand hover:text-brand',
    popular: false,
    delay: 1,
  },
  {
    name: t.pricingPage.proName,
    subtitle: t.pricingPage.proSubtitle,
    price: t.pricingPage.proPrice,
    priceSuffix: t.pricingPage.proPriceSuffix,
    features: t.pricingPage.proFeatures,
    cta: t.pricingPage.proCta,
    ctaStyle: 'bg-brand text-white hover:bg-brand-dark shadow-[0_2px_16px_-4px_rgba(34,197,94,0.4)]',
    popular: true,
    delay: 2,
  },
  {
    name: t.pricingPage.enterpriseName,
    subtitle: t.pricingPage.enterpriseSubtitle,
    price: t.pricingPage.enterprisePrice,
    priceSuffix: t.pricingPage.enterprisePriceSuffix,
    features: t.pricingPage.enterpriseFeatures,
    cta: t.pricingPage.enterpriseCta,
    ctaStyle: 'border border-border text-text-primary hover:border-brand hover:text-brand',
    popular: false,
    delay: 3,
  },
]

const comparisonFeatures = t.pricingPage.comparisonFeatures as Array<{
  name: string
  starter: string | boolean
  pro: string | boolean
  enterprise: string | boolean
}>
---

<Layout locale={locale} title={`${t.pricingPage.title} — Gobbly`} description={t.pricingPage.description} path="/pricing/">
  <Navbar locale={locale} />
  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-5xl mx-auto px-6 pt-4">
      <Breadcrumbs locale={locale} items={[
        { label: t.nav.home, href: `/${locale}/` },
        { label: t.pricingPage.title },
      ]} />
    </div>

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 text-center mb-20">
      <div class="fade-up">
        <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-4">{t.pricing.label}</p>
        <h1 class="font-display text-4xl md:text-6xl tracking-tight mb-6">{t.pricingPage.heroTitle}</h1>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">{t.pricingPage.heroSubtitle}</p>
      </div>
    </section>

    <!-- Plan Cards -->
    <section class="max-w-5xl mx-auto px-6 mb-24">
      <div class="grid md:grid-cols-3 gap-6">
        {plans.map((plan) => (
          <div class:list={[
            `fade-up fade-up-delay-${plan.delay} bg-surface-card rounded-2xl p-8 flex flex-col transition-transform duration-300 hover:-translate-y-1`,
            plan.popular ? 'pricing-glow relative md:scale-105' : 'border border-border',
          ]}>
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-brand text-white text-xs font-semibold rounded-full">
                {t.pricingPage.mostPopular}
              </div>
            )}
            <div class="mb-6">
              <h3 class="text-lg font-semibold text-text-primary">{plan.name}</h3>
              <p class="text-sm text-text-muted mt-1">{plan.subtitle}</p>
            </div>
            <div class="mb-6">
              <span class="font-display text-4xl tracking-tight text-text-primary">{plan.price}</span>
              {plan.priceSuffix && <span class="text-text-muted text-sm">{plan.priceSuffix}</span>}
            </div>
            <ul class="space-y-3 mb-8 flex-1">
              {plan.features.map((feature: string) => (
                <li class="flex items-start gap-2.5 text-sm text-text-secondary">
                  <CheckIcon />
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            <a href={`/${locale}/contact/`} class={`block text-center px-6 py-3 rounded-full text-sm font-semibold transition-colors ${plan.ctaStyle}`}>
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- Feature Comparison Table -->
    <section class="max-w-5xl mx-auto px-6 mb-24">
      <div class="text-center mb-14">
        <h2 class="fade-up font-display text-3xl md:text-5xl tracking-tight mb-4">{t.pricingPage.comparisonTitle}</h2>
        <p class="fade-up fade-up-delay-1 text-text-secondary max-w-lg mx-auto">{t.pricingPage.comparisonSubtitle}</p>
      </div>
      <div class="fade-up fade-up-delay-2 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-4 pr-4 font-semibold text-text-primary">{t.pricingPage.featureLabel}</th>
              <th class="text-center py-4 px-4 font-semibold text-text-primary">{t.pricingPage.starterName}</th>
              <th class="text-center py-4 px-4 font-semibold text-brand">{t.pricingPage.proName}</th>
              <th class="text-center py-4 px-4 font-semibold text-text-primary">{t.pricingPage.enterpriseName}</th>
            </tr>
          </thead>
          <tbody>
            {comparisonFeatures.map((feature) => (
              <tr class="border-b border-border/50">
                <td class="py-4 pr-4 text-text-secondary">{feature.name}</td>
                <td class="py-4 px-4 text-center">
                  {typeof feature.starter === 'boolean' ? (
                    feature.starter ? (
                      <span class="inline-flex justify-center"><CheckIcon /></span>
                    ) : (
                      <span class="text-text-muted">&mdash;</span>
                    )
                  ) : (
                    <span class="text-text-secondary">{feature.starter}</span>
                  )}
                </td>
                <td class="py-4 px-4 text-center">
                  {typeof feature.pro === 'boolean' ? (
                    feature.pro ? (
                      <span class="inline-flex justify-center"><CheckIcon /></span>
                    ) : (
                      <span class="text-text-muted">&mdash;</span>
                    )
                  ) : (
                    <span class="text-text-secondary">{feature.pro}</span>
                  )}
                </td>
                <td class="py-4 px-4 text-center">
                  {typeof feature.enterprise === 'boolean' ? (
                    feature.enterprise ? (
                      <span class="inline-flex justify-center"><CheckIcon /></span>
                    ) : (
                      <span class="text-text-muted">&mdash;</span>
                    )
                  ) : (
                    <span class="text-text-secondary">{feature.enterprise}</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-3xl mx-auto px-6 mb-24">
      <div class="text-center mb-14">
        <h2 class="fade-up font-display text-3xl md:text-5xl tracking-tight mb-4">{t.pricingPage.faqTitle}</h2>
        <p class="fade-up fade-up-delay-1 text-text-secondary max-w-lg mx-auto">{t.pricingPage.faqSubtitle}</p>
      </div>
      <div class="space-y-6">
        {t.pricingPage.faq.map((item: { question: string; answer: string }, i: number) => (
          <div class={`fade-up fade-up-delay-${Math.min(i + 1, 3)} bg-surface-card rounded-2xl border border-border p-6`}>
            <h3 class="text-base font-semibold text-text-primary mb-2">{item.question}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.answer}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Final CTA -->
    <section class="max-w-4xl mx-auto px-6 text-center">
      <div class="fade-up bg-surface-card rounded-2xl border border-border p-10 md:p-14">
        <h2 class="font-display text-2xl md:text-4xl tracking-tight mb-4">{t.pricingPage.ctaTitle}</h2>
        <p class="text-text-secondary mb-8 max-w-lg mx-auto">{t.pricingPage.ctaSubtitle}</p>
        <a href={`/${locale}/contact/`} class="inline-flex items-center px-8 py-3.5 bg-brand text-white text-sm font-semibold rounded-full hover:bg-brand-dark transition-colors shadow-[0_2px_16px_-4px_rgba(34,197,94,0.4)]">
          {t.pricingPage.ctaButton}
        </a>
      </div>
    </section>
  </main>
  <Footer locale={locale} />

  <JsonLd schema={{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Gobbly",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": t.pricingPage.description,
    "offers": [
      {
        "@type": "Offer",
        "name": t.pricingPage.starterName,
        "price": "0",
        "priceCurrency": "EUR",
        "description": t.pricingPage.starterSubtitle,
      },
      {
        "@type": "Offer",
        "name": t.pricingPage.proName,
        "price": "49",
        "priceCurrency": "EUR",
        "billingIncrement": "P1M",
        "description": t.pricingPage.proSubtitle,
      },
      {
        "@type": "Offer",
        "name": t.pricingPage.enterpriseName,
        "price": "0",
        "priceCurrency": "EUR",
        "description": t.pricingPage.enterpriseSubtitle,
      },
    ],
  }} />
</Layout>
