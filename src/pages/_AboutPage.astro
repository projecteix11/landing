---
import Layout from '@layouts/Layout.astro'
import Breadcrumbs from '@components/ui/Breadcrumbs.astro'
import JsonLd from '@components/ui/JsonLd.astro'
import Navbar from '@components/layout/Navbar.astro'
import Footer from '@components/layout/Footer.astro'
import '@styles/global.css'
import type { Locale } from '@i18n/types'
import { getTranslations } from '@i18n/utils'

interface Props { locale: Locale }
const { locale } = Astro.props
const t = getTranslations(locale)

const founderConfig = [
  { initials: 'MS', gradient: 'from-brand to-brand-dark' },
  { initials: 'EV', gradient: 'from-terracotta to-amber' },
  { initials: 'PR', gradient: 'from-blue to-blue/70' },
]

const valueIcons = [
  /* Simplicity */ '<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />',
  /* Real-time */ '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />',
  /* Transparency */ '<path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />',
  /* Local */ '<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />',
]
---

<Layout locale={locale} title={`${t.about.title} — Gobbly`} description={t.about.subtitle} path="/about/">
  <!-- JSON-LD structured data -->
  <!-- TODO: Replace with real company data -->
  <JsonLd schema={{
    "@context": "https://schema.org",
    "@type": "SoftwareCompany",
    "name": "Gobbly",
    "url": "https://gobbly.app",
    "logo": "https://gobbly.app/favicon.svg",
    "description": t.about.subtitle,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Barcelona",
      "addressRegion": "Catalunya",
      "addressCountry": "ES"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "availableLanguage": ["Spanish", "Catalan", "English"]
    }
  }} />

  <Navbar locale={locale} />
  <main class="pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-5xl mx-auto px-6 pt-4">
      <Breadcrumbs locale={locale} items={[
        { label: t.nav.home, href: `/${locale}/` },
        { label: t.about.title },
      ]} />
    </div>

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 text-center mb-20">
      <div class="fade-up">
        <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-4">{t.about.foundersLabel}</p>
        <h1 class="font-display text-4xl md:text-6xl tracking-tight mb-6">{t.about.title}</h1>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">{t.about.subtitle}</p>
      </div>
    </section>

    <!-- Our Story -->
    <section class="max-w-4xl mx-auto px-6 mb-20">
      <div class="fade-up bg-surface-card rounded-2xl border border-border p-10 md:p-14">
        <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-4">{t.about.story.title}</p>
        <div class="space-y-5">
          {t.about.story.paragraphs.map((paragraph) => (
            <p class="text-text-secondary leading-relaxed text-lg">{paragraph}</p>
          ))}
        </div>
      </div>
    </section>

    <!-- Founders -->
    <section class="max-w-5xl mx-auto px-6 mb-20">
      <div class="grid md:grid-cols-3 gap-8">
        {founderConfig.map((config, i) => (
          <div class="fade-up fade-up-delay-1 bg-surface-card rounded-2xl border border-border p-8 text-center">
            <div class={`w-20 h-20 rounded-full bg-gradient-to-br ${config.gradient} flex items-center justify-center text-white text-2xl font-semibold mx-auto mb-5`}>
              {config.initials}
            </div>
            <p class="text-lg font-semibold text-text-primary mb-1">{t.about.founders[i].name}</p>
            <p class="text-sm text-brand font-medium mb-4">{t.about.founders[i].role}</p>
            <p class="text-text-secondary text-sm leading-relaxed">{t.about.founders[i].bio}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Our Values -->
    <section class="max-w-5xl mx-auto px-6 mb-20">
      <div class="fade-up text-center mb-12">
        <h2 class="font-display text-2xl md:text-4xl tracking-tight">{t.about.values.title}</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-8">
        {t.about.values.items.map((value, i) => (
          <div class="fade-up fade-up-delay-1 bg-surface-card rounded-2xl border border-border p-8">
            <div class="w-12 h-12 rounded-xl bg-brand-soft flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={valueIcons[i]} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">{value.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Numbers -->
    <!-- TODO: Replace placeholder data with real metrics -->
    <section class="max-w-5xl mx-auto px-6 mb-20">
      <div class="fade-up text-center mb-12">
        <h2 class="font-display text-2xl md:text-4xl tracking-tight">{t.about.numbers.title}</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {t.about.numbers.items.map((stat) => (
          <div class="fade-up fade-up-delay-1 bg-surface-card rounded-2xl border border-border p-6 text-center">
            <p class="text-3xl md:text-4xl font-display font-bold text-brand mb-2">{stat.value}</p>
            <p class="text-text-secondary text-sm">{stat.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Mission -->
    <section class="max-w-4xl mx-auto px-6">
      <div class="fade-up bg-surface-card rounded-2xl border border-border p-10 md:p-14">
        <p class="text-xs font-semibold text-brand uppercase tracking-widest mb-4">{t.about.missionLabel}</p>
        <h2 class="font-display text-2xl md:text-4xl tracking-tight mb-6">{t.about.missionTitle}</h2>
        <p class="text-text-secondary leading-relaxed text-lg">{t.about.missionText}</p>
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</Layout>
